# cc-0013 dashboard — local env template.
#
# Copy to .env.local and populate. .env.local is gitignored; do not commit.
# Do NOT prefix any of these with NEXT_PUBLIC_ — they are server-only.
#
# SUPABASE_URL: Supabase project URL (https://<project-ref>.supabase.co).
# SUPABASE_SERVICE_ROLE_KEY: service-role JWT. Server-side only.
#   - Used by lib/supabase/server.ts via process.env.
#   - NEVER expose to client (no NEXT_PUBLIC_ prefix; no client-side import of
#     lib/supabase/server.ts; `server-only` package raises a build error on
#     accidental client import).

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
