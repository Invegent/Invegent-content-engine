# cc-0013 dashboard — local env template.
#
# Copy to .env.local and populate. .env.local is gitignored; do not commit.
# Do NOT prefix any of these with NEXT_PUBLIC_ — they are server-only.
#
# SUPABASE_URL: Supabase project URL (https://<project-ref>.supabase.co).
# SUPABASE_SERVICE_ROLE_KEY: service-role JWT. Server-side only.
#   - Used by lib/supabase/server.ts via process.env.
#   - NEVER expose to client (no NEXT_PUBLIC_ prefix; no client-side import of
#     lib/supabase/server.ts; `server-only` package raises a build error on
#     accidental client import).

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- CCD-PRV-002 Path A: direct read-only Postgres transport (server-only) ---
# PRV_READONLY_DATABASE_URL: read-only Postgres connection string for the
#   /recon read-only MVP, which reads the cc-0012 op.* views directly (schema
#   `op` is not exposed to PostgREST, so supabase-js REST cannot reach it).
#   - Server-only. NEVER prefix with NEXT_PUBLIC_. NEVER commit a real value.
#   - This is a database URL, NOT the service-role API key.
#   - lib/db.ts also forces a read-only session (default_transaction_read_only=on),
#     so no write can pass through even with a privileged login role.
#   - `op_reader` is NOLOGIN, so use a login role holding SELECT on op.* (e.g. postgres).
#   Format (Supabase session pooler, recommended):
#     postgresql://postgres.<project-ref>:<DB_PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres
#   or direct:
#     postgresql://postgres:<DB_PASSWORD>@db.<project-ref>.supabase.co:5432/postgres
PRV_READONLY_DATABASE_URL=
